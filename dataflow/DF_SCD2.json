{
	"name": "DF_SCD2",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "DS_DataLake_Source",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				},
				{
					"linkedService": {
						"referenceName": "DS_DataLake_Source",
						"type": "LinkedServiceReference"
					},
					"name": "source2"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "DS_DataLake_Source",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "derivedColumn2"
				},
				{
					"name": "exists1"
				},
				{
					"name": "isactivew"
				},
				{
					"name": "select1"
				},
				{
					"name": "exists2"
				},
				{
					"name": "exists3"
				},
				{
					"name": "derivedColumn3"
				},
				{
					"name": "alterRow1"
				},
				{
					"name": "union1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          customer_id as string,",
				"          created_date as date,",
				"          modified_date as date,",
				"          sales_id as short",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'DataFactory/Input/DataFlow',",
				"     fileName: 'sales_stage_dataflow.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true,",
				"     partitionBy('hash', 1)) ~> source1",
				"source(output(",
				"          customer_id as string,",
				"          created_date as date,",
				"          modified_date as date,",
				"          sales_id as short,",
				"          is_active as boolean",
				"     ),",
				"     useSchema: false,",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'DataFactory/Output/DataFlow',",
				"     fileName: 'sales_target_dataflow.csv',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: true) ~> source2",
				"source1 derive(hash = md5(sales_id,customer_id,created_date,modified_date),",
				"     partitionBy('hash', 1)) ~> derivedColumn1",
				"source2 derive(hash = md5(sales_id,customer_id,created_date,modified_date)) ~> derivedColumn2",
				"derivedColumn1, derivedColumn2 exists(derivedColumn1@hash == derivedColumn2@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists1",
				"exists1 derive(is_active = 1) ~> isactivew",
				"isactivew select(mapColumn(",
				"          customer_id,",
				"          created_date,",
				"          modified_date,",
				"          sales_id,",
				"          is_active",
				"     ),",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> select1",
				"derivedColumn1, derivedColumn2 exists(source1@sales_id == source2@sales_id,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists2",
				"exists2, derivedColumn2 exists(derivedColumn1@hash == derivedColumn2@hash,",
				"     negate:true,",
				"     broadcast: 'auto')~> exists3",
				"exists3 derive(is_active = 0) ~> derivedColumn3",
				"derivedColumn3 alterRow(updateIf(true())) ~> alterRow1",
				"select1, alterRow1 union(byName: true)~> union1",
				"union1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'delimited',",
				"     fileSystem: 'landing',",
				"     folderPath: 'DataFactory/Output/DataFlow',",
				"     columnDelimiter: ',',",
				"     escapeChar: '\\\\',",
				"     quoteChar: '\\\"',",
				"     columnNamesAsHeader: false,",
				"     partitionFileNames:['sales_target_dataflow.csv'],",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     partitionBy('hash', 1)) ~> sink1"
			]
		}
	}
}